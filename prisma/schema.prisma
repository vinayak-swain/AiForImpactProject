datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String?
  name             String
  avatarUrl        String?
  provider         String    @default("email") // email | google | github
  roleTarget       String    // e.g. "Backend SDE", "ML Engineer"
  experienceLevel  String    // fresher | junior | mid | senior
  isPro            Boolean   @default(false)
  streak           Int       @default(0)
  lastActiveDate   DateTime?
  createdAt        DateTime  @default(now())
  sessions         Session[]
  resumes          Resume[]
  badges           Badge[]
}

model Resume {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  s3Key        String
  parsedJson   Json     // { projects[], skills[], experiences[], education[] }
  uploadedAt   DateTime @default(now())
}

model Session {
  id            String     @id @default(cuid())
  userId        String
  user         User       @relation(fields: [userId], references: [id])
  interviewType String     // behavioural | technical | resume_based
  role          String
  durationMins  Int
  overallScore  Float?
  grade         String?    // A | B | C | D
  reportS3Key   String?
  startedAt     DateTime   @default(now())
  endedAt       DateTime?
  questions     Question[]
}

model Question {
  id           String   @id @default(cuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id])
  questionText String
  questionType String   // behavioural | technical | resume_based
  difficulty   String   // easy | medium | hard
  orderIndex   Int
  answer       Answer?
}

model Answer {
  id           String   @id @default(cuid())
  questionId   String   @unique
  question     Question @relation(fields: [questionId], references: [id])
  userId       String
  answerText   String   @db.Text
  wordCount    Int
  submittedAt  DateTime @default(now())
  score        Score?
}

model Score {
  id               String  @id @default(cuid())
  answerId         String  @unique
  answer           Answer  @relation(fields: [answerId], references: [id])
  starScore        Float   // 0-25
  techDepthScore   Float   // 0-25
  commScore        Float   // 0-20
  relevanceScore   Float   // 0-15
  confidenceScore  Float   // 0-10
  concisenessScore Float   // 0-5
  overallScore     Float   // 0-100
  aiFeedbackJson   Json
  // aiFeedbackJson shape:
  // { star: {situation, task, action, result},
  //   topStrength, topWeakness,
  //   fillerWords[], idealAnswerSkeleton }
}

model Badge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  badgeType String   // streak_7 | streak_30 | score_80 | sessions_10
  earnedAt  DateTime @default(now())
}
